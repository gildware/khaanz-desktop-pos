{
  "name": "khaanz-pos-desktop-offline",
  "private": true,
  "version": "0.1.0",
  "description": "Offline-first desktop POS (Electron + React + SQLite) with sync outbox.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "npm --prefix renderer run dev",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run build:renderer",
    "build:renderer": "npm --prefix renderer run build",
    "predist": "npm run build:renderer",
    "dist": "electron-builder --publish never",
    "dist:publish": "electron-builder --publish always",
    "start": "electron ."
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "concurrently": "^9.2.1",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.3",
    "zod": "^4.1.5"
  },
  "build": {
    "appId": "com.khaanz.pos.desktop",
    "productName": "Khaanz POS",
    "publish": {
      "provider": "github",
      "owner": "gildware",
      "repo": "khaanz-desktop-pos"
    },
    "icon": "logo/khaanz-logo.pdf.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!renderer/src{,/**}",
      "!renderer/node_modules{,/**}",
      "!renderer/**/*.ts",
      "!renderer/**/*.tsx",
      "!renderer/index.html",
      "!renderer/postcss.config.mjs",
      "!renderer/tsconfig.json",
      "!renderer/vite.config.ts",
      "!release{,/**}",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/renderer/dist/**"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
