# Copy to `.env` in this folder:  cp .env.example .env
# Must match POS_SYNC_KEY in khaanz/.env (same shared secret).

# Your Khaanz server (local dev or production URL, no trailing slash).
# Installed app: put this file in the user-data folder (see README), not only next to the repo.
KHAANZ_API_ORIGIN="http://localhost:3000"

# Same value as POS_SYNC_KEY on the server
KHAANZ_SYNC_KEY="change-me-pos-sync-secret"

# Optional
# KHAANZ_OPEN_DEVTOOLS=1
# KHAANZ_SILENT_PRINTER="Your Printer Name"
